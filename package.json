{
  "name": "stellar-starter-kit-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "The fastest way to build modern Stellar and Soroban applications.",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release-packages": "changeset publish",
    "download:cli": "powershell -ExecutionPolicy Bypass -File ./scripts/download-stellar-cli.ps1",
    "build:contracts": "powershell -ExecutionPolicy Bypass -File ./scripts/build-contracts.ps1",
    "optimize": "powershell -ExecutionPolicy Bypass -File ./scripts/optimize-contracts.ps1",
    "deploy:testnet": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-contracts.ps1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.5.20",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "turbo": "^2.0.4",
    "typescript": "^5.5.2"
  },
  "packageManager": "pnpm@9.4.0",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ]
  }
}
